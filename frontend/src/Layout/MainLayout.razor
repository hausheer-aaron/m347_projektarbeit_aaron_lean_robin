@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="false" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<div style="min-height:100vh; display:flex; flex-direction:column; background:#f0f4f8;">

    <!-- Nav -->
    <nav style="position:sticky; top:0; z-index:100; background:rgba(255,255,255,0.85); backdrop-filter:blur(16px); border-bottom:1px solid #e2e8f0; padding:0 2rem;">
        <div style="max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; height:56px;">
            <a href="/" style="display:flex; align-items:center; gap:0.5rem; text-decoration:none;">
                <MudIcon Icon="@Icons.Material.Filled.Cloud" Style="font-size:22px; color:#6366f1;" />
                <span style="font-size:1.05rem; font-weight:700; color:#1e293b; letter-spacing:-0.01em;">WeatherApp</span>
            </a>
            <div style="display:flex; gap:0.25rem;">
                <a href="/" style="padding:0.4rem 0.85rem; border-radius:6px; color:#64748b; text-decoration:none; font-size:0.82rem; font-weight:500; transition:background 0.2s;">Wetter</a>
                <a href="/planner" style="padding:0.4rem 0.85rem; border-radius:6px; color:#64748b; text-decoration:none; font-size:0.82rem; font-weight:500; transition:background 0.2s;">Tagesplaner</a>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <main style="flex:1;">
        @Body
    </main>
</div>
