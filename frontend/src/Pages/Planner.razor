@page "/planner"
@using WeatherApp.Frontend.Models
@using WeatherApp.Frontend.Services

<PageTitle>Tagesplaner</PageTitle>

<div style="max-width:700px; margin:0 auto; padding:1.5rem 1.5rem 2rem;">

    <!-- Date navigator -->
    <div class="fade-in" style="display:flex; align-items:center; justify-content:center; gap:1rem; margin-bottom:1.5rem;">
        <button class="nav-arrow" @onclick="@(() => ChangeDate(-1))">‹</button>

        @{
            var today = DateOnly.FromDateTime(DateTime.Now);
            for (int d = -3; d <= 3; d++)
            {
                var date = selectedDate.AddDays(d);
                var isSelected = date == selectedDate;
                var isToday = date == today;
                <div class="date-chip @(isSelected ? "selected" : "") @(isToday && !isSelected ? "today" : "")"
                     @onclick="@(() => { selectedDate = date; _ = LoadActivities(); })">
                    <span style="font-size:0.65rem; font-weight:500;">@date.ToString("ddd")</span>
                    <span style="font-size:1rem; font-weight:700;">@date.Day</span>
                </div>
            }
        }

        <button class="nav-arrow" @onclick="@(() => ChangeDate(1))">›</button>
    </div>

    <!-- Date title -->
    <div class="fade-in" style="text-align:center; margin-bottom:1.25rem;">
        <div style="font-size:1.2rem; font-weight:700; color:#1e293b;">
            @selectedDate.ToString("dddd, d. MMMM")
        </div>
    </div>

    <!-- Activities list -->
    <div class="fade-in-d1" style="display:flex; flex-direction:column; gap:0.6rem; margin-bottom:1.25rem;">
        @if (activities.Count == 0 && !showForm)
        {
            <div class="weather-card" style="text-align:center; padding:2rem; color:#94a3b8;">
                <div style="font-size:2rem; margin-bottom:0.5rem;">??</div>
                Keine Aktivitäten für diesen Tag
            </div>
        }

        @foreach (var a in activities)
        {
            <div class="weather-card" style="padding:1rem 1.25rem; cursor:pointer; transition:box-shadow 0.2s;"
                 @onclick="@(() => StartEdit(a))">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.4rem;">
                    <div style="font-size:1rem; font-weight:700; color:#1e293b;">
                        @a.From.ToString("HH:mm") – @a.To.ToString("HH:mm") · @a.Title
                        <span style="margin-left:0.3rem;">@GetActivityEmoji(a)</span>
                    </div>
                    <button style="background:none; border:none; cursor:pointer; font-size:1rem; color:#94a3b8; padding:0.2rem;"
                            @onclick:stopPropagation="true" @onclick="@(() => DeleteActivity(a.Id))">?</button>
                </div>
                <div style="height:1px; background:#f1f5f9; margin-bottom:0.4rem;"></div>
                <div style="font-size:0.82rem; color:#64748b;">
                    @if (!string.IsNullOrEmpty(a.Location))
                    {
                        <span>?? @a.Location</span>
                    }
                    @if (a.IsWeekly)
                    {
                        <span> · ?? Wöchentlich</span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Add / Edit form -->
    @if (showForm)
    {
        <div class="weather-card fade-in" style="padding:1.25rem; margin-bottom:1rem;">
            <div style="font-size:0.95rem; font-weight:700; color:#1e293b; margin-bottom:1rem;">
                @(isEdit ? "Aktivität bearbeiten" : "Neue Aktivität")
            </div>

            <div style="display:flex; flex-direction:column; gap:0.75rem;">
                <div>
                    <label class="form-label">Titel</label>
                    <input type="text" class="form-input" placeholder="z.B. Spaziergang, Joggen, Einkaufen..."
                           @bind="editActivity.Title" />
                </div>

                <div style="position:relative;">
                    <label class="form-label">Ort</label>
                    <input type="text" class="form-input" placeholder="Ort eingeben..."
                           value="@editActivity.Location"
                           @oninput="OnLocationInput"
                           @onfocus="@(() => { locationSuggestions = WeatherRecommendation.GetLocationSuggestions(editActivity.Location); showLocationDropdown = locationSuggestions.Count > 0; })"
                           @onblur="@(async () => { await Task.Delay(150); showLocationDropdown = false; })" />
                    @if (showLocationDropdown)
                    {
                        <div class="location-dropdown">
                            @foreach (var loc in locationSuggestions)
                            {
                                <div class="location-option" @onmousedown="@(() => SelectLocation(loc))">
                                    ?? @loc
                                </div>
                            }
                        </div>
                    }
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
                    <div>
                        <label class="form-label">Von</label>
                        <input type="time" class="form-input" @bind="editActivity.From" />
                    </div>
                    <div>
                        <label class="form-label">Bis</label>
                        <input type="time" class="form-input" @bind="editActivity.To" />
                    </div>
                </div>

                <label class="toggle-label">
                    <input type="checkbox" @bind="editActivity.IsWeekly" />
                    <span>?? Wöchentlich wiederholen</span>
                </label>

                <div style="display:flex; gap:0.5rem; justify-content:flex-end; margin-top:0.25rem;">
                    <button class="tab-btn" @onclick="CancelForm">Abbrechen</button>
                    <button class="tab-btn active" @onclick="SaveActivity">Speichern</button>
                </div>
            </div>
        </div>
    }

    <!-- Add button -->
    @if (!showForm)
    {
        <div class="fade-in-d2" style="text-align:center;">
            <button class="add-btn" @onclick="StartNew">
                <span style="font-size:1.25rem; line-height:1;">+</span>
                Aktivität hinzufügen
            </button>
        </div>
    }
</div>
