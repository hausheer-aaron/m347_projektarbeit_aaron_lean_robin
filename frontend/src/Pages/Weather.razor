@page "/"
@using System.Linq
@using WeatherApp.Frontend.Models

<PageTitle>Weather</PageTitle>

@if (isLoading)
{
    <div style="display:flex; align-items:center; justify-content:center; min-height:60vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (forecast is not null)
{
    var hourlyData = GetHourlyData();
    var dailyData = GetDailyData();
    var vals = hourlyData.Select(h => activeTab == 0 ? h.Temp : activeTab == 1 ? h.Precip : h.Wind).ToArray();
    var lo = vals.Length > 0 ? vals.Min() - 1 : 0;
    var hi = vals.Length > 0 ? vals.Max() + 1 : 1;
    var range = Math.Max(1, hi - lo);
    var sfx = activeTab == 0 ? "°" : activeTab == 1 ? "%" : " km/h";
    var selDay = SelectedDayData;
    var chartH = 140;

    <div style="display:flex; flex-direction:column; gap:0.75rem; padding:1rem 2rem 1.25rem;">

        <!-- Row 1: Hero + Stats -->
        <div class="fade-in" style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
            <div class="weather-card" style="display:flex; align-items:center; gap:1.25rem; padding:1.25rem 1.75rem;">
                <span style="font-size:3.5rem; line-height:1;">@GetWeatherEmoji(forecast.Current?.WeatherCode ?? 0)</span>
                <div>
                    <div style="font-size:3rem; font-weight:800; line-height:1; color:#1e293b; letter-spacing:-0.03em;">
                        @CurrentTemp<span style="font-size:1.2rem; font-weight:400; color:#94a3b8;">°C</span>
                    </div>
                    <div style="font-size:0.88rem; color:#64748b; margin-top:0.25rem;">@CurrentCondition · @locationName</div>
                </div>
            </div>

            <div class="weather-card" style="display:grid; grid-template-columns:1fr 1fr; gap:0; padding:0;">
                @if (hourlyData.Count > 0)
                {
                    var now = hourlyData[0];
                    <div class="stat-cell">
                        <span class="stat-emoji">💧</span>
                        <span class="stat-value">@(now.Precip)%</span>
                        <span class="stat-label">Niederschlag</span>
                    </div>
                    <div class="stat-cell">
                        <span class="stat-emoji">💨</span>
                        <span class="stat-value">@(now.Wind) km/h</span>
                        <span class="stat-label">Wind</span>
                    </div>
                }
                @if (selDay is not null)
                {
                    <div class="stat-cell">
                        <span class="stat-emoji">🌡️</span>
                        <span class="stat-value">@((int)Math.Round(selDay.TemperatureMax ?? 0))° / @((int)Math.Round(selDay.TemperatureMin ?? 0))°</span>
                        <span class="stat-label">Hoch / Tief</span>
                    </div>
                    <div class="stat-cell">
                        <span class="stat-emoji">🌅</span>
                        <span class="stat-value">@(selDay.Sunrise?.ToString("HH:mm") ?? "–")</span>
                        <span class="stat-label">Sonnenaufgang</span>
                    </div>
                }
            </div>
        </div>

        <!-- Row 2: Tabs + MyDay link -->
        <div class="fade-in-d1" style="display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #e2e8f0;">
            <div style="display:flex; gap:0;">
                <button class="chart-tab @(activeTab==0?"active":"")" @onclick="@(() => activeTab=0)">Temperatur</button>
                <button class="chart-tab @(activeTab==1?"active":"")" @onclick="@(() => activeTab=1)">Niederschlag</button>
                <button class="chart-tab @(activeTab==2?"active":"")" @onclick="@(() => activeTab=2)">Wind</button>
            </div>
            <div class="myday-link" @onclick="OpenMyDayOverlay">
                📋 Mein Tag
                @if (todayActivities.Count > 0)
                {
                    <span class="myday-count">@todayActivities.Count</span>
                }
            </div>
        </div>

        <!-- Row 3: Area chart -->
        @if (hourlyData.Count > 0)
        {
            var count = hourlyData.Count;
            var step = 130;
            var svgW = count * step;

            <div class="fade-in-d2" style="overflow-x:auto; padding-bottom:4px;">
                <div style="min-width:@(svgW)px; position:relative;">
                    <div style="display:flex; height:30px; align-items:flex-end;">
                        @foreach (var h in hourlyData)
                        {
                            var v = activeTab == 0 ? h.Temp : activeTab == 1 ? h.Precip : h.Wind;
                            <div style="width:@(step)px; text-align:center; font-size:0.95rem; font-weight:700; color:#1e293b;">@v</div>
                        }
                    </div>

                    <svg width="@svgW" height="@chartH" style="display:block;">
                        @{
                            var points = new List<string>();
                            for (int i = 0; i < count; i++)
                            {
                                var v = activeTab == 0 ? hourlyData[i].Temp : activeTab == 1 ? hourlyData[i].Precip : hourlyData[i].Wind;
                                var x = i * step + step / 2;
                                var y = chartH - (int)(((v - lo) / (double)range) * (chartH - 20)) - 10;
                                points.Add($"{x},{y}");
                            }
                            var linePoints = string.Join(" ", points);
                            var firstX = step / 2;
                            var lastX = (count - 1) * step + step / 2;
                            var areaPoints = $"{firstX},{chartH} {linePoints} {lastX},{chartH}";
                        }
                        <defs>
                            <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#6366f1" stop-opacity="0.35" />
                                <stop offset="100%" stop-color="#6366f1" stop-opacity="0.03" />
                            </linearGradient>
                        </defs>
                        <polygon points="@areaPoints" fill="url(#areaGrad)" />
                        <polyline points="@linePoints" fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
                        @for (int i = 0; i < count; i++)
                        {
                            var v = activeTab == 0 ? hourlyData[i].Temp : activeTab == 1 ? hourlyData[i].Precip : hourlyData[i].Wind;
                            var x = i * step + step / 2;
                            var y = chartH - (int)(((v - lo) / (double)range) * (chartH - 20)) - 10;
                            <circle cx="@x" cy="@y" r="4" fill="#fff" stroke="#6366f1" stroke-width="2" />
                        }
                    </svg>

                    <div style="display:flex; height:28px; align-items:flex-start; margin-top:4px;">
                        @foreach (var h in hourlyData)
                        {
                            <div style="width:@(step)px; text-align:center; font-size:0.82rem; color:#94a3b8; font-weight:500;">@h.Time</div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="weather-card fade-in-d2" style="text-align:center; padding:2rem; color:#94a3b8;">Keine Stundendaten für diesen Tag</div>
        }

        <!-- Row 4: 7-day -->
        @if (dailyData.Count > 0)
        {
            <div class="fade-in-d3" style="display:flex; gap:8px;">
                @for (var i = 0; i < dailyData.Count; i++)
                {
                    var idx = i;
                    var d = dailyData[i];
                    <div class="day-pill @(selectedDayIndex == idx ? "selected" : "")" @onclick="@(() => SelectDay(idx))" style="padding:0.6rem 0.5rem;">
                        <div class="day-label" style="font-size:0.78rem; font-weight:600;">@d.Day</div>
                        <span style="font-size:1.6rem; line-height:1; margin:5px 0;">@GetWeatherEmoji(d.Code)</span>
                        <div style="display:flex; gap:0.4rem; justify-content:center; align-items:baseline;">
                            <span class="day-high" style="font-size:0.88rem; font-weight:700;">@d.High°</span>
                            <span class="day-low" style="font-size:0.75rem; opacity:0.5;">@d.Low°</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- MyDay Overlay -->
    @if (showMyDayOverlay)
    {
        var packList = GetPackList();

        <div class="overlay-backdrop" @onclick="CloseMyDayOverlay">
            <div class="overlay-panel" @onclick:stopPropagation="true">
                <!-- Header -->
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                    <div style="font-size:1.15rem; font-weight:700; color:#1e293b;">
                        📅 @DateTime.Now.ToString("dddd, d. MMMM")
                    </div>
                    <button class="overlay-close" @onclick="CloseMyDayOverlay">✕</button>
                </div>

                @if (todayActivities.Count == 0)
                {
                    <div style="text-align:center; padding:2rem 1rem; color:#94a3b8;">
                        <div style="font-size:2.5rem; margin-bottom:0.5rem;">📋</div>
                        <div style="font-size:0.95rem; margin-bottom:0.75rem;">Keine Aktivitäten für heute.</div>
                        <a href="/planner" class="add-btn" style="text-decoration:none;">+ Jetzt planen</a>
                    </div>
                }
                else
                {
                    <!-- Activity cards -->
                    <div style="display:flex; flex-direction:column; gap:0.6rem; margin-bottom:1.25rem;">
                        @foreach (var a in todayActivities)
                        {
                            var recs = GetActivityRecommendations(a);
                            var summary = GetActivityWeatherSummary(a);
                            <div class="overlay-activity">
                                <div style="font-size:1rem; font-weight:700; color:#1e293b; margin-bottom:0.25rem;">
                                    @a.From.ToString("HH:mm") – @a.Title @GetActivityEmoji(a.Title)
                                </div>
                                @if (!string.IsNullOrEmpty(a.Location))
                                {
                                    <div style="font-size:0.78rem; color:#94a3b8; margin-bottom:0.3rem;">📍 @a.Location</div>
                                }
                                <div style="height:1px; background:#e2e8f0; margin-bottom:0.4rem;"></div>
                                @if (recs.Count > 0)
                                {
                                    <div style="font-size:0.78rem; color:#64748b; font-weight:600; margin-bottom:0.15rem;">Empfehlung:</div>
                                    <ul style="margin:0; padding-left:1.1rem; font-size:0.85rem; color:#475569; line-height:1.6;">
                                        @foreach (var r in recs)
                                        {
                                            <li>@r.Emoji @r.Label</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <div style="font-size:0.82rem; color:#94a3b8;">@summary — Alles gut, nichts Spezielles nötig ✅</div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Pack list -->
                    @if (packList.Count > 0)
                    {
                        <div style="border-top:2px solid #f1f5f9; padding-top:1rem;">
                            <div style="text-align:center; font-size:1rem; font-weight:700; color:#1e293b; margin-bottom:0.75rem;">
                                Packliste für heute
                            </div>
                            <div style="display:flex; gap:1.75rem; justify-content:center; flex-wrap:wrap;">
                                @foreach (var item in packList)
                                {
                                    <div style="text-align:center;">
                                        <div style="font-size:2rem;">@item.Emoji</div>
                                        <div style="font-size:0.75rem; color:#475569; font-weight:500; margin-top:0.15rem;">@item.Label</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div style="text-align:center; margin-top:1rem;">
                        <a href="/planner" style="font-size:0.82rem; color:#6366f1; text-decoration:none; font-weight:600;">Tagesplaner öffnen →</a>
                    </div>
                }
            </div>
        </div>
    }
}
