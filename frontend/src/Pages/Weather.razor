@page "/"
@using MudBlazor
@using System.Linq

<PageTitle>Weather</PageTitle>

@{
    int[] vals = hourly.Select(h => activeTab == 0 ? h.Temp : activeTab == 1 ? h.Precip : h.Wind).ToArray();
    int lo = vals.Min(), hi = vals.Max(), span = Math.Max(1, hi - lo);
    string suffix = activeTab == 0 ? "°" : activeTab == 1 ? "%" : " km/h";
}

<div style="max-width:1100px; margin:0 auto; padding:2.5rem 2rem 3rem;">

    <!-- Hero: large temp, condition, location -->
    <div class="fade-in" style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:2.5rem;">
        <div style="display:flex; align-items:center; gap:1.25rem;">
            <MudIcon Icon="@Icons.Material.Filled.Cloud" Style="font-size:80px; color:#818cf8; opacity:0.9;" />
            <div>
                <div style="font-size:4rem; font-weight:800; line-height:1; color:#f1f5f9; letter-spacing:-0.03em;">
                    @(isCelsius ? currentTemp : ToF(currentTemp))<span style="font-size:1.5rem; font-weight:400; color:#64748b;">@(isCelsius ? "°C" : "°F")</span>
                </div>
                <div style="font-size:1rem; color:#64748b; margin-top:0.25rem;">Stark bewölkt · Zürich</div>
            </div>
        </div>

        <div style="display:flex; gap:2.5rem; padding-bottom:0.5rem;">
            <div>
                <div style="font-size:0.7rem; color:#475569; text-transform:uppercase; letter-spacing:0.05em;">Niederschlag</div>
                <div style="font-size:1.1rem; color:#e2e8f0; font-weight:600;">11%</div>
            </div>
            <div>
                <div style="font-size:0.7rem; color:#475569; text-transform:uppercase; letter-spacing:0.05em;">Luftfeuchte</div>
                <div style="font-size:1.1rem; color:#e2e8f0; font-weight:600;">73%</div>
            </div>
            <div>
                <div style="font-size:0.7rem; color:#475569; text-transform:uppercase; letter-spacing:0.05em;">Wind</div>
                <div style="font-size:1.1rem; color:#e2e8f0; font-weight:600;">16 km/h</div>
            </div>
        </div>
    </div>

    <!-- Divider -->
    <div style="height:1px; background:rgba(255,255,255,0.06); margin-bottom:1.5rem;"></div>

    <!-- Tabs + unit toggle -->
    <div class="fade-in-d1" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <div style="display:flex; gap:0.4rem;">
            <button class="tab-btn @(activeTab==0?"active":"")" @onclick="@(() => activeTab=0)">Temperatur</button>
            <button class="tab-btn @(activeTab==1?"active":"")" @onclick="@(() => activeTab=1)">Niederschlag</button>
            <button class="tab-btn @(activeTab==2?"active":"")" @onclick="@(() => activeTab=2)">Wind</button>
        </div>
        <button class="tab-btn" @onclick="@(() => isCelsius = !isCelsius)">@(isCelsius ? "°C" : "°F")</button>
    </div>

    <!-- Hourly chart — full width, no box -->
    <div class="fade-in-d2" style="display:flex; align-items:end; gap:6px; height:130px; margin-bottom:2.5rem;">
        @foreach (var h in hourly)
        {
            int v = activeTab == 0 ? h.Temp : activeTab == 1 ? h.Precip : h.Wind;
            int barH = (int)(((v - lo) / (double)span) * 90) + 16;
            <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:flex-end;">
                <span style="font-size:0.72rem; color:#94a3b8; margin-bottom:4px;">@v@suffix</span>
                <div class="weather-bar" style="width:100%; height:@(barH)px; background:linear-gradient(180deg,#818cf8,#6366f1);"></div>
                <span style="font-size:0.68rem; color:#475569; margin-top:6px;">@h.Time</span>
            </div>
        }
    </div>

    <!-- 7-day — simple row, no cards -->
    <div class="fade-in-d3" style="display:flex; gap:2px;">
        @foreach (var d in daily)
        {
            <div style="flex:1; text-align:center; padding:0.75rem 0; border-radius:10px; transition:background 0.2s;"
                 onmouseenter="this.style.background='rgba(99,102,241,0.06)'" onmouseleave="this.style.background='transparent'">
                <div style="font-size:0.75rem; color:#475569; margin-bottom:0.35rem;">@d.Day</div>
                <MudIcon Icon="@d.Icon" Style="font-size:24px; color:#818cf8;" />
                <div style="font-size:0.95rem; font-weight:700; color:#e2e8f0; margin-top:0.3rem;">@d.High°</div>
                <div style="font-size:0.75rem; color:#475569;">@d.Low°</div>
            </div>
        }
    </div>
</div>

@code {
    private bool isCelsius = true;
    private int activeTab;
    private int currentTemp => hourly.FirstOrDefault()?.Temp ?? 0;
    private int ToF(int c) => (int)Math.Round(c * 9.0 / 5.0 + 32);
}
